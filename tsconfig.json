{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "declaration": true,
        "sourceMap": true,
        "declarationMap": true,
        "jsx": "react-jsx",
        "skipLibCheck": true
    },
    "include": ["src/**/*"]
}
